generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id            String   @id @default(cuid())
  wallet        String   @unique
  pda           String   @unique
  owner         String
  metadataUri   String
  registeredAt  DateTime
  isVerified    Boolean  @default(false)
  verifiedAt    DateTime?
  sponsored     Boolean  @default(false)  // Was registration sponsored (free)?
  
  // Extended metadata (cached from AgentCard)
  name          String?
  description   String?
  twitter       String?
  website       String?
  image         String?  // Avatar/profile picture URL
  
  // Service endpoints
  mcpEndpoint   String?
  a2aEndpoint   String?
  x402Wallet    String?
  serviceTypes  String[]  @default([])
  skills        String[]  @default([])
  
  // Layer 2 verification (endpoint challenge-response)
  layer2Verified      Boolean  @default(false)
  layer2VerifiedAt    DateTime?
  verifiedEndpointUrl String?
  l2AttestationMethod String?
  registrationSource  String?
  activityCount       Int      @default(0)
  lastActiveAt        DateTime?

  // Passport (soulbound NFT)
  passportMint        String?
  passportMintedAt    DateTime?
  passportTxHash      String?

  // Reputation
  reputationScore Float   @default(0)
  feedbackCount   Int     @default(0)
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastSyncedAt  DateTime @default(now())
  
  // Relations
  feedbackReceived Feedback[] @relation("FeedbackReceived")
  feedbackGiven    Feedback[] @relation("FeedbackGiven")
  attestationsReceived Attestation[] @relation("AttestationsReceived")
  attestationsGiven    Attestation[] @relation("AttestationsGiven")
  createdByUsers   UserAgent[]
  capabilities     Capability[]

  @@index([name])
  @@index([reputationScore])
  @@index([isVerified])
}

model Feedback {
  id          String   @id @default(cuid())
  
  // Who gave feedback
  fromWallet  String
  fromAgent   Agent?   @relation("FeedbackGiven", fields: [fromWallet], references: [wallet])
  
  // Who received feedback
  toWallet    String
  toAgent     Agent    @relation("FeedbackReceived", fields: [toWallet], references: [wallet])
  
  // Feedback content
  score       Int      // 0-100
  comment     String?
  weight      Float    @default(1.0)  // Verified agents = 2.0, others = 1.0
  
  // Verification
  signature   String   // Wallet signature proving authenticity
  fromIsVerified Boolean @default(false) // Was giver verified at time of feedback?
  txHash      String?  // On-chain hash if stored on-chain
  
  createdAt   DateTime @default(now())

  @@unique([fromWallet, toWallet])
  @@index([toWallet])
  @@index([score])
}

model SyncState {
  id          String   @id @default("main")
  lastSlot    BigInt   @default(0)
  lastSyncAt  DateTime @default(now())
}

model AgentCard {
  id          String   @id @default(cuid())
  wallet      String   @unique
  cardJson    String   // JSON blob of the agent card
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([wallet])
}

model Attestation {
  id              String    @id @default(cuid())
  
  // Who is attesting
  attesterWallet  String
  attester        Agent     @relation("AttestationsGiven", fields: [attesterWallet], references: [wallet])
  
  // Who is being attested
  subjectWallet   String
  subject         Agent     @relation("AttestationsReceived", fields: [subjectWallet], references: [wallet])
  
  // Attestation details
  type            String    @default("trust")  // trust, endorsement, interaction, skill
  confidence      Int       @default(50)       // 1-100
  context         String?                      // Optional note/reason
  skill           String?                      // For skill attestations: which skill
  
  // Verification
  signature       String?                      // Wallet signature (optional for trusted sources)
  txHash          String?                      // On-chain anchor (future)
  
  // Lifecycle
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  revokedAt       DateTime?
  
  @@unique([attesterWallet, subjectWallet, type])
  @@index([subjectWallet])
  @@index([attesterWallet])
  @@index([type])
}

model User {
  id              String    @id @default(cuid())
  
  // Login methods (one of these is set)
  privyId         String?   @unique
  walletAddress   String?   @unique
  email           String?   @unique
  emailVerified   Boolean   @default(false)
  
  // Profile
  displayName     String?
  username        String?   @unique
  avatarUrl       String?   @db.Text
  
  // Session management
  sessionToken    String?   @unique
  sessionExpiry   DateTime?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime  @default(now())
  
  // Relations
  agents          UserAgent[]
  
  @@index([privyId])
  @@index([walletAddress])
  @@index([email])
  @@index([sessionToken])
}

model UserAgent {
  id              String    @id @default(cuid())
  
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  agentWallet     String
  agent           Agent     @relation(fields: [agentWallet], references: [wallet], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  
  @@unique([userId, agentWallet])
  @@index([userId])
  @@index([agentWallet])
}

model GrantApplication {
  id               String   @id @default(cuid())
  agentName        String
  walletAddress    String
  twitter          String?
  website          String?
  description      String
  useCase          String
  fundingAmount    String
  fundingDuration  String
  milestones       String
  teamBackground   String?
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([walletAddress])
  @@index([status])
}

model AgentChallenge {
  id          String   @id @default(cuid())
  wallet      String
  nonce       String   @unique
  endpointUrl String
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  verified    Boolean  @default(false)
  verifiedAt  DateTime?

  @@index([wallet])
  @@index([nonce])
}

model EmailOTP {
  id              String    @id @default(cuid())
  email           String
  code            String
  expiresAt       DateTime
  verified        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  
  @@index([email])
  @@index([code])
}

model WebhookConfig {
  id              String    @id @default(cuid())
  platform        String    // e.g., "spawnr"
  url             String
  events          String[]  // e.g., ["reputation_change", "verification_complete"]
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([platform])
}

model Capability {
  id          String   @id @default(cuid())
  wallet      String
  capability  String
  endpoint    String
  description String?
  pricing     Json?
  chain       String   @default("solana")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  active      Boolean  @default(true)

  agent       Agent    @relation(fields: [wallet], references: [wallet])

  @@unique([wallet, capability])
  @@index([capability])
  @@index([chain])
}

model CrossChainWebhook {
  id        String   @id @default(cuid())
  chain     String
  address   String
  url       String
  secret    String?  // HMAC-SHA256 signing key
  createdAt DateTime @default(now())

  @@unique([chain, address])
  @@index([chain, address])
}

model A2AMessage {
  id          String   @id @default(cuid())
  
  // Routing
  fromWallet  String
  toWallet    String
  
  // Content
  message     String   @db.Text
  context     String?  @db.Text  // JSON
  
  // Task tracking
  taskId      String?  @unique
  status      String   @default("created")  // created, working, complete, failed
  progress    Int      @default(0)
  result      String?  @db.Text  // JSON
  
  // Verification
  fromVerified Boolean @default(false)
  signature   String?
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([toWallet])
  @@index([fromWallet])
  @@index([status])
  @@index([createdAt])
}

model WalletLink {
  id          String   @id @default(cuid())
  
  // On-chain state (cache)
  pda         String   @unique
  agentPda    String   // Points to Agent.pda
  wallet      String   @unique
  
  // Metadata
  linkedAt    DateTime @default(now())
  lastSynced  DateTime @default(now())
  
  @@index([wallet])
  @@index([agentPda])
}

// ========================================
// MARKETPLACE MODELS
// ========================================

model AgentListing {
  id          String   @id @default(cuid())
  agentWallet String   // Must have verified SAID passport
  
  // Listing details
  title       String
  description String   @db.Text
  skills      String[] @default([])
  
  // Pricing (at least one required)
  priceSOL    Float?
  priceUSDC   Float?
  hourlyRate  Float?
  
  // Status
  available   Boolean  @default(true)
  featured    Boolean  @default(false)
  
  // Stats (computed from jobs)
  jobsCompleted Int     @default(0)
  rating        Float?  // Average rating
  totalEarned   Float   @default(0)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  jobs        Job[]
  reviews     Review[]
  
  @@index([agentWallet])
  @@index([available])
  @@index([rating])
  @@index([featured])
}

model Job {
  id          String   @id @default(cuid())
  
  // References
  listingId   String
  listing     AgentListing @relation(fields: [listingId], references: [id])
  
  // Participants
  clientWallet String  // Wallet hiring the agent
  agentWallet  String  // Cached from listing
  
  // Job details
  title        String
  description  String   @db.Text
  budgetSOL    Float?
  budgetUSDC   Float?
  
  // Status flow: pending -> accepted -> in_progress -> completed/cancelled/disputed
  status      String   @default("pending")
  
  // Escrow tracking
  escrowTx    String?  // Transaction hash for escrow deposit
  releaseTx   String?  // Transaction hash for payment release
  
  // Timestamps
  acceptedAt  DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  review      Review?
  
  @@index([listingId])
  @@index([clientWallet])
  @@index([agentWallet])
  @@index([status])
  @@index([createdAt])
}

model Review {
  id          String   @id @default(cuid())
  
  // References
  jobId       String   @unique
  job         Job      @relation(fields: [jobId], references: [id])
  listingId   String
  listing     AgentListing @relation(fields: [listingId], references: [id])
  
  // Review content
  rating      Int      // 1-5 stars
  comment     String?  @db.Text
  reviewerWallet String // Client who left review
  
  // Verification (optional on-chain anchor)
  signature   String?
  txHash      String?
  
  createdAt   DateTime @default(now())
  
  @@index([listingId])
  @@index([rating])
}
