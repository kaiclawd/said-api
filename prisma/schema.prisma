generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id            String   @id @default(cuid())
  wallet        String   @unique
  pda           String   @unique
  owner         String
  metadataUri   String
  registeredAt  DateTime
  isVerified    Boolean  @default(false)
  verifiedAt    DateTime?
  sponsored     Boolean  @default(false)  // Was registration sponsored (free)?
  
  // Extended metadata (cached from AgentCard)
  name          String?
  description   String?
  twitter       String?
  website       String?
  image         String?  // Avatar/profile picture URL
  
  // Service endpoints
  mcpEndpoint   String?
  a2aEndpoint   String?
  x402Wallet    String?
  serviceTypes  String[]  @default([])
  skills        String[]  @default([])
  
  // Layer 2 verification (endpoint challenge-response)
  layer2Verified      Boolean  @default(false)
  layer2VerifiedAt    DateTime?
  verifiedEndpointUrl String?
  l2AttestationMethod String?
  registrationSource  String?
  activityCount       Int      @default(0)
  lastActiveAt        DateTime?

  // Passport (soulbound NFT)
  passportMint        String?
  passportMintedAt    DateTime?
  passportTxHash      String?

  // Reputation
  reputationScore Float   @default(0)
  feedbackCount   Int     @default(0)
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastSyncedAt  DateTime @default(now())
  
  // Relations
  feedbackReceived Feedback[] @relation("FeedbackReceived")
  feedbackGiven    Feedback[] @relation("FeedbackGiven")
  attestationsReceived Attestation[] @relation("AttestationsReceived")
  attestationsGiven    Attestation[] @relation("AttestationsGiven")
  createdByUsers   UserAgent[]
  capabilities     Capability[]
  trustScore       AgentScore?
  
  // Delegated Signing Authority
  agentWallets     AgentWallet[]
  transactionRequests TransactionRequest[]
  apiKeys          ApiKey[]
  transactionPolicy TransactionPolicy?

  @@index([name])
  @@index([reputationScore])
  @@index([isVerified])
}

model Feedback {
  id          String   @id @default(cuid())
  
  // Who gave feedback
  fromWallet  String
  fromAgent   Agent?   @relation("FeedbackGiven", fields: [fromWallet], references: [wallet])
  
  // Who received feedback
  toWallet    String
  toAgent     Agent    @relation("FeedbackReceived", fields: [toWallet], references: [wallet])
  
  // Feedback content
  score       Int      // 0-100
  comment     String?
  weight      Float    @default(1.0)  // Verified agents = 2.0, others = 1.0
  
  // Verification
  signature   String   // Wallet signature proving authenticity
  fromIsVerified Boolean @default(false) // Was giver verified at time of feedback?
  txHash      String?  // On-chain hash if stored on-chain
  
  createdAt   DateTime @default(now())

  @@unique([fromWallet, toWallet])
  @@index([toWallet])
  @@index([score])
}

model SyncState {
  id          String   @id @default("main")
  lastSlot    BigInt   @default(0)
  lastSyncAt  DateTime @default(now())
}

model AgentCard {
  id          String   @id @default(cuid())
  wallet      String   @unique
  cardJson    String   // JSON blob of the agent card
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([wallet])
}

model Attestation {
  id              String    @id @default(cuid())
  
  // Who is attesting
  attesterWallet  String
  attester        Agent     @relation("AttestationsGiven", fields: [attesterWallet], references: [wallet])
  
  // Who is being attested
  subjectWallet   String
  subject         Agent     @relation("AttestationsReceived", fields: [subjectWallet], references: [wallet])
  
  // Attestation details
  type            String    @default("trust")  // trust, endorsement, interaction, skill
  confidence      Int       @default(50)       // 1-100
  context         String?                      // Optional note/reason
  skill           String?                      // For skill attestations: which skill
  
  // Verification
  signature       String?                      // Wallet signature (optional for trusted sources)
  txHash          String?                      // On-chain anchor (future)
  
  // Lifecycle
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  revokedAt       DateTime?
  
  @@unique([attesterWallet, subjectWallet, type])
  @@index([subjectWallet])
  @@index([attesterWallet])
  @@index([type])
}

model User {
  id              String    @id @default(cuid())
  
  // Login methods (one of these is set)
  privyId         String?   @unique
  walletAddress   String?   @unique
  email           String?   @unique
  emailVerified   Boolean   @default(false)
  
  // Profile
  displayName     String?
  username        String?   @unique
  avatarUrl       String?   @db.Text
  
  // Session management
  sessionToken    String?   @unique
  sessionExpiry   DateTime?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime  @default(now())
  
  // Relations
  agents          UserAgent[]
  
  @@index([privyId])
  @@index([walletAddress])
  @@index([email])
  @@index([sessionToken])
}

model UserAgent {
  id              String    @id @default(cuid())
  
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  agentWallet     String
  agent           Agent     @relation(fields: [agentWallet], references: [wallet], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  
  @@unique([userId, agentWallet])
  @@index([userId])
  @@index([agentWallet])
}

model GrantApplication {
  id               String   @id @default(cuid())
  agentName        String
  walletAddress    String
  twitter          String?
  website          String?
  description      String
  useCase          String
  fundingAmount    String
  fundingDuration  String
  milestones       String
  teamBackground   String?
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([walletAddress])
  @@index([status])
}

model AgentChallenge {
  id          String   @id @default(cuid())
  wallet      String
  nonce       String   @unique
  endpointUrl String
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  verified    Boolean  @default(false)
  verifiedAt  DateTime?

  @@index([wallet])
  @@index([nonce])
}

model EmailOTP {
  id              String    @id @default(cuid())
  email           String
  code            String
  expiresAt       DateTime
  verified        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  
  @@index([email])
  @@index([code])
}

model WebhookConfig {
  id              String    @id @default(cuid())
  platform        String    // e.g., "spawnr"
  url             String
  events          String[]  // e.g., ["reputation_change", "verification_complete"]
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([platform])
}

model Capability {
  id          String   @id @default(cuid())
  wallet      String
  capability  String
  endpoint    String
  description String?
  pricing     Json?
  chain       String   @default("solana")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  active      Boolean  @default(true)

  agent       Agent    @relation(fields: [wallet], references: [wallet])

  @@unique([wallet, capability])
  @@index([capability])
  @@index([chain])
}

model CrossChainWebhook {
  id        String   @id @default(cuid())
  chain     String
  address   String
  url       String
  secret    String?  // HMAC-SHA256 signing key
  createdAt DateTime @default(now())

  @@unique([chain, address])
  @@index([chain, address])
}

model A2AMessage {
  id          String   @id @default(cuid())
  
  // Routing
  fromWallet  String
  toWallet    String
  
  // Content
  message     String   @db.Text
  context     String?  @db.Text  // JSON
  
  // Task tracking
  taskId      String?  @unique
  status      String   @default("created")  // created, working, complete, failed
  progress    Int      @default(0)
  result      String?  @db.Text  // JSON
  
  // Verification
  fromVerified Boolean @default(false)
  signature   String?
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([toWallet])
  @@index([fromWallet])
  @@index([status])
  @@index([createdAt])
}

model AgentScore {
  id              String    @id @default(cuid())
  wallet          String    @unique
  score           Int       @default(0)       // 0-100
  tier            String    @default("unverified")
  
  // SAID Engine breakdown (recomputed every 6h)
  identity        Float     @default(0)
  activity        Float     @default(0)
  economic        Float     @default(0)
  ecosystem       Float     @default(0)
  longevity       Float     @default(0)
  
  // FairScale enrichment (recomputed every 7d)
  fairscale       Float     @default(0)
  fairscaleRaw    Json?     // Raw FairScale API response
  fairscaleAt     DateTime? // When FairScale was last fetched
  
  badges          String[]  @default([])
  flags           String[]  @default([])
  sources         String[]  @default(["said"])
  
  computedAt      DateTime  @default(now())   // Last full computation
  lastQueriedAt   DateTime  @default(now())   // Last time someone requested this score
  
  agent           Agent     @relation(fields: [wallet], references: [wallet])
  
  @@index([score(sort: Desc)])
  @@index([tier])
  @@index([computedAt])
  @@index([lastQueriedAt])
}

model WalletLink {
  id          String   @id @default(cuid())
  
  // On-chain state (cache)
  pda         String   @unique
  agentPda    String   // Points to Agent.pda
  wallet      String   @unique
  
  // Metadata
  linkedAt    DateTime @default(now())
  lastSynced  DateTime @default(now())
  
  @@index([wallet])
  @@index([agentPda])
}

// ============================================================
// Delegated Signing Authority — Privy Agent Wallets
// ============================================================

model AgentWallet {
  id                String    @id @default(cuid())
  
  // Links to existing agent identity
  agentId           String
  agent             Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  // Wallet details
  publicKey         String    @unique   // Solana public key (from Privy)
  provider          String    @default("privy")  // privy, mock
  providerWalletId  String?   // Privy's internal wallet identifier
  
  // Wallet type
  walletType        String    @default("transaction")  // transaction, subscription
  isPrimary         Boolean   @default(false)  // Is this the agent's primary transaction wallet?
  
  // Status
  status            String    @default("active")  // active, suspended, revoked
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Metadata from Privy
  metadata          Json?
  
  // Relations
  transactions      TransactionRequest[]
  
  @@unique([agentId, walletType])  // One wallet per type per agent
  @@index([agentId])
  @@index([publicKey])
  @@index([status])
}

model TransactionRequest {
  id                String    @id @default(cuid())
  
  // Who requested it
  agentId           String
  agent             Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  walletId          String
  wallet            AgentWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  apiKeyId          String?
  apiKey            ApiKey?   @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  
  // Transaction details
  type              String    // transfer, swap, register, custom
  token             String    // USDC, SOL, etc.
  amount            Decimal   @db.Decimal(18, 6)
  recipient         String?   // Destination address
  programId         String?   // Solana program being called
  memo              String?
  
  // Raw transaction data
  serializedTx      String?   @db.Text  // Base64 serialized unsigned tx
  
  // Policy check
  policyPassed      Boolean?
  policyReason      String?   // Why approved/denied
  
  // Execution
  status            String    @default("pending")  // pending, approved, denied, signing, broadcast, confirmed, failed
  txHash            String?   // Solana transaction signature
  errorMessage      String?
  
  // Timestamps
  createdAt         DateTime  @default(now())
  signedAt          DateTime?
  broadcastAt       DateTime?
  confirmedAt       DateTime?
  
  @@index([agentId, createdAt(sort: Desc)])
  @@index([status])
  @@index([txHash])
}

model ApiKey {
  id                String    @id @default(cuid())
  
  // Who owns this key
  agentId           String
  agent             Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  // Key data (we store hash, never the raw key)
  keyHash           String    @unique
  keyPrefix         String    // First 12 chars for identification: said_ak_xxxx
  name              String?   // Human-readable label
  
  // Permissions
  scopes            String[]  @default(["wallet", "transaction"])
  
  // Rate limiting
  rateLimitPerHour  Int       @default(100)
  
  // Lifecycle
  createdAt         DateTime  @default(now())
  lastUsedAt        DateTime?
  expiresAt         DateTime?
  revokedAt         DateTime?
  
  // Who created this (user session token or admin)
  createdBy         String?
  
  // Relations
  transactions      TransactionRequest[]
  
  @@index([agentId])
  @@index([keyHash])
  @@index([keyPrefix])
}

model TransactionPolicy {
  id                    String    @id @default(cuid())
  
  // One policy per agent
  agentId               String    @unique
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  // Spending limits (in USDC equivalent)
  maxPerTransaction     Decimal   @default(10.00)  @db.Decimal(10, 2)
  maxPerDay             Decimal   @default(100.00) @db.Decimal(10, 2)
  maxPerMonth           Decimal   @default(1000.00) @db.Decimal(10, 2)
  
  // Token restrictions
  allowedTokens         String[]  @default(["USDC", "SOL"])
  
  // Program restrictions (Solana program IDs)
  allowedPrograms       String[]  @default([])
  
  // Approval thresholds
  requireApprovalAbove  Decimal   @default(50.00) @db.Decimal(10, 2)
  
  // Status
  status                String    @default("active")  // active, suspended
  
  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([agentId])
}
